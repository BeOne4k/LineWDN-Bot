# Server
PORT=3000
WEBHOOK_URL=https://YOUR_DOMAIN.com/webhook

# Odoo CRM
ODOO_URL=https://your-odoo-instance.com
ODOO_DB=your_database
ODOO_USERNAME=bot@weeden.com
ODOO_PASSWORD=your_odoo_password

# OTP service (e.g. Twilio / 2Factor / your provider)
OTP_PROVIDER_URL=https://api.your-otp-provider.com
OTP_API_KEY=your_otp_api_key

# AI (optional — for manager handoff AI responses)
OPENAI_API_KEY=your_openai_key

# Store database (simple JSON path or external API)
STORES_API_URL=https://your-stores-api.com/stores
# OR leave empty to use local stores.json

# Google Maps deep link base
GOOGLE_MAPS_BASE=https://www.google.com/maps/dir/?api=1&destination=
